{
  "name": "@birchill/normal-jp",
  "version": "1.7.2",
  "description": "Various Japanese text conversion utilities",
  "author": "Brian Birtles",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "prepublishOnly": "tsdown",
    "prepare": "husky",
    "ci:publish": "pnpm changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/birchill/normal-jp.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "bugs": {
    "url": "https://github.com/birchill/normal-jp/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "homepage": "https://github.com/birchill/normal-jp#readme",
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@types/node": "24.13.3",
    "husky": "9.1.7",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "tsdown": "0.22.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
